# Cloudflare Bindings (configured in wrangler.toml)
# These are automatically injected by Wrangler
# VISIBILITY_DB: D1 Database instance
# ANALYTICS_CACHE or MARKETER_CACHE: KV namespace for caching

# Analytics Worker
ENVIRONMENT=development
ANALYTICS_CACHE_ID=analytics-cache-id

# Marketer Worker  
ANALYTICS_WORKER_URL=http://localhost:8787

# Optional: External Services (for future implementation)
SENDGRID_API_KEY=
STRIPE_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
