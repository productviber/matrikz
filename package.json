{
  "name": "visibility-platform",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Full-stack monolithic workers for Visibility Cockpit platform",
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "deploy": "pnpm -r deploy",
    "clean": "pnpm -r clean && rm -rf node_modules pnpm-lock.yaml",
    "secrets:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/setup-secrets.ps1"
  },
  "devDependencies": {
    "pnpm": "^10.30.0",
    "typescript": "^5.3.0"
  },
  "pnpm": {
    "overrides": {
      "react": "^18.2.0",
      "react-dom": "^18.2.0"
    }
  }
}
