{
  "name": "visibility-marketing",
  "version": "1.0.0",
  "type": "module",
  "description": "Event-driven marketing worker for Visibility — affiliate growth loop, CRM, email sequences, and campaign management",
  "scripts": {
    "dev": "wrangler dev",
    "build": "vite build",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=dot",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:smoke": "node tests/smoke.mjs",
    "test:smoke:skrip": "node scripts/skrip-smoke.mjs",
    "test:all": "vitest run && node tests/smoke.mjs",
    "db:migrate": "wrangler d1 migrations apply visibility-marketing-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply visibility-marketing-db --remote",
    "activate": "node scripts/activate.mjs",
    "activate:check": "node scripts/activate.mjs --check",
    "lint": "tsc --noEmit",
    "ci": "pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "dependencies": {
    "@matrikz/growth-agent-contracts": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^2.0.0",
    "wrangler": "^3.0.0"
  }
}